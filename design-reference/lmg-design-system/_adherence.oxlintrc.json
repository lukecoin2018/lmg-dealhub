{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/Badge/**",
              "components/Button/**",
              "components/ServiceCard/**",
              "components/StatTile/**",
              "design-canvas.jsx",
              "explorations/**",
              "ui_kits/website/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Playfair Display|Manrope|DM Sans|JetBrains Mono))/i]",
        "message": "Font not provided by the design system. Available: Playfair Display, Manrope, DM Sans, JetBrains Mono."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:tone|icon|children|className|style|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: tone, icon, children, className, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:neutral|yellow|pink|blue|dark|outline)$/]",
        "message": "<Badge> tone must be one of 'neutral' | 'yellow' | 'pink' | 'blue' | 'dark' | 'outline'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|icon|iconRight|children|onClick|type|className|style|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, icon, iconRight, children, onClick, type, className, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|secondary|blue|ghost|outline|dark)$/]",
        "message": "<Button> variant must be one of 'primary' | 'secondary' | 'blue' | 'ghost' | 'outline' | 'dark'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='type'] > Literal[value!=/^(?:button|submit|reset)$/]",
        "message": "<Button> type must be one of 'button' | 'submit' | 'reset'."
      },
      {
        "selector": "JSXOpeningElement[name.name='ServiceCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:audience|pill|photo|icon|title|description|features|moreCount|primaryLabel|secondaryLabel|onPrimary|onSecondary|key|ref|className|style|children)$/]",
        "message": "<ServiceCard> doesn't accept that prop. Declared props: audience, pill, photo, icon, title, description, features, moreCount, primaryLabel, secondaryLabel, onPrimary, onSecondary."
      },
      {
        "selector": "JSXOpeningElement[name.name='ServiceCard'] > JSXAttribute[name.name='audience'] > Literal[value!=/^(?:brand|influencer)$/]",
        "message": "<ServiceCard> audience must be one of 'brand' | 'influencer'."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatTile'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|label|tone|key|ref|className|style|children)$/]",
        "message": "<StatTile> doesn't accept that prop. Declared props: value, label, tone."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatTile'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:blue|pink|yellow)$/]",
        "message": "<StatTile> tone must be one of 'blue' | 'pink' | 'yellow'."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
